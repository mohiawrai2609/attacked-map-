// ─────────────────────────────────────────────────────────────────────────
// SubscriptionsPage — "Compose your intelligence" preference centre (?subscriptions).
//
// Reference: the attacked-subscriptions-v3 composer — a light/paper surface
// where a signed-in member composes their edition: pick a role, tune risk
// categories + sectors, set cadence, confirm. A sticky "Your edition" rail
// summarises the selection and saves it.
//
// REAL wiring (persisted via update_subscription_prefs RPC):
//   • Risk category alerts   → watch_categories
//   • Sector intelligence    → watch_industries
//   • Cadence                → digest_frequency
//   • Master subscribe       → email_subscribed
// Aspirational modules (flagship/recurring briefings, regions, simulations,
// playbooks) are shown as "Coming soon" so the page reads complete without
// fake-functional toggles.
//
// Theme: light/paper body between the app's dark nav + footer (a deliberate
// editorial mix). Anonymous visitors bounce to the landing page.
// ─────────────────────────────────────────────────────────────────────────
import React, { useEffect, useMemo, useState } from "react";
import { supabase } from "../lib/supabaseClient";
import { useAuth } from "./AuthProvider";
import { SiteNav } from "./SiteNav";
import { SiteFooter } from "./SiteFooter";

const C = {
  paper: "#FFFFFF", paper2: "#FAFAF8", paper3: "#F4F4F1",
  ink: "#101010", ink2: "#3A3A3A", ink3: "#707070", ink4: "#9A9A98",
  line: "#E7E7E3", line2: "#D6D6D1",
  gold: "#F5B800", goldDeep: "#A87C00", goldWash: "#FFF7DE", goldLine: "rgba(245,184,0,0.45)",
  ok: "#1E8E3E", err: "#C0392B",
};
const FONT = "Inter, sans-serif";
const MONO = "'JetBrains Mono', ui-monospace, monospace";

const CATEGORIES = [
  ["CYB", "Cyber Security"], ["DAT", "Data & Privacy"], ["TEC", "Technology"], ["GEO", "Geopolitical"],
  ["PHY", "Physical Security"], ["OPS", "Operations"], ["TPR", "Third Party"], ["REG", "Regulatory"],
  ["FIN", "Financial"], ["STR", "Strategic"], ["REP", "Reputation"], ["PPL", "People"], ["ENV", "Environmental"],
];

const SECTORS = [
  ["Communication Services", ["Advertising & Marketing Services", "Media & Entertainment", "Telecommunications"]],
  ["Consumer Discretionary", ["Apparel, Luxury & Sporting Goods", "Automotive & EV", "Broadline & Specialty Retail", "Hotels, Restaurants & Leisure"]],
  ["Consumer Staples", ["Food & Beverage", "Food & Drug Retail", "Household & Personal Care"]],
  ["Defence & National Security", ["Armed Forces & Defence Ministries"]],
  ["Energy", ["Oil & Gas (Integrated & E&P)", "Oil & Gas Services & Midstream", "Renewable Energy & Clean Tech", "Utilities (Electric, Gas, Water)"]],
  ["Financials", ["Banking (Diversified & Universal)", "Capital Markets & Asset Management", "Consumer Finance & Lending", "Insurance", "Payments & Financial Infrastructure"]],
  ["Healthcare", ["Health Insurance & Managed Care", "Healthcare Facilities & Providers", "Life Sciences & Biotech Tools", "Medical Devices & Equipment", "Pharmaceuticals"]],
  ["Industrials", ["Aerospace & Defence", "Airlines & Aviation", "Construction & Engineering", "Industrial Machinery & Equipment", "Transportation & Logistics", "Waste Management & Environmental Services"]],
  ["Information Technology", ["Cybersecurity", "Hardware & Networking", "Internet & Digital Platforms", "IT Services & Consulting", "Semiconductors & Equipment", "Software & Cloud Infrastructure"]],
  ["Materials", ["Chemicals (Diversified & Specialty)", "Metals, Mining & Building Materials"]],
  ["Public Administration", ["Government (National / Federal)"]],
  ["Public Health & Social Care", ["Public Hospitals & National Health Systems"]],
  ["Real Estate", ["Real Estate Development & Services", "REITs (All Subsectors)"]],
];
const ALL_INDUSTRIES = SECTORS.flatMap(([, list]) => list);
const ALL_CATS = CATEGORIES.map(c => c[0]);

const PERSONAS = [
  { key: "ciso", k: "01", title: "Security & CISO", desc: "Live campaigns, named exposure and the controls that contain them.", cats: ["CYB", "DAT", "TPR", "TEC"], families: ["Information Technology"] },
  { key: "board", k: "02", title: "Board & C-Suite", desc: "The risks that move valuation, reputation and resilience.", cats: ["STR", "FIN", "REP", "REG", "GEO"], all: true },
  { key: "risk", k: "03", title: "Risk & Resilience", desc: "Operational, financial and regulatory incidents, scored.", cats: ["OPS", "REG", "FIN", "TPR", "ENV"], all: true },
  { key: "analyst", k: "04", title: "Analyst & Research", desc: "The full breadth — every category, every sector.", cats: ALL_CATS, all: true },
];

const COMING = [
  { t: "Flagship briefings", d: "The Daily Sweep, Board Brief, Monthly Heatmap." },
  { t: "Sector & vector roundups", d: "The Signal, Week in Vectors, Vendor Watch, FDRI Quarterly." },
  { t: "Regions", d: "Bias your intelligence toward the regions that matter." },
  { t: "Crisis simulations", d: "Wargaming.ai scenario drops & war-room invitations." },
];

function FontLoader() {
  useEffect(() => {
    if (document.getElementById("attacked-fonts-sub")) return;
    const l = document.createElement("link");
    l.id = "attacked-fonts-sub"; l.rel = "stylesheet";
    l.href = "https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap";
    document.head.appendChild(l);
  }, []);
  return null;
}

export function SubscriptionsPage() {
  const { user, loading: authLoading, refreshProfile } = useAuth();
  const [loading, setLoading] = useState(true);
  const [saving, setSaving] = useState(false);
  const [saved, setSaved] = useState(false);
  const [error, setError] = useState(null);

  const [subscribed, setSubscribed] = useState(true);
  const [freq, setFreq] = useState("daily");
  const [watchAllInd, setWatchAllInd] = useState(true);
  const [inds, setInds] = useState([]);          // when not watch-all
  const [allRisks, setAllRisks] = useState(true);
  const [cats, setCats] = useState([]);          // when not all-risks
  const [activePersona, setActivePersona] = useState(null);
  const [email, setEmail] = useState("");
  const [openSector, setOpenSector] = useState(null);

  useEffect(() => {
    if (authLoading) return;
    let preview = false;
    try { preview = !!new URLSearchParams(window.location.search).get("preview"); } catch { /* noop */ }
    if (!user && !preview) { window.location.href = "/"; return; }
    if (user) setEmail(user.email || "");
    let cancelled = false;
    (async () => {
      if (!user) { setLoading(false); return; } // preview without a session → show defaults
      try {
        const { data } = await supabase.from("profiles")
          .select("email_subscribed, digest_frequency, watch_industries, watch_categories")
          .eq("id", user.id).maybeSingle();
        if (cancelled || !data) { setLoading(false); return; }
        setSubscribed(data.email_subscribed !== false);
        setFreq(data.digest_frequency || "daily");
        const wi = Array.isArray(data.watch_industries) ? data.watch_industries : [];
        const wc = Array.isArray(data.watch_categories) ? data.watch_categories : [];
        const allI = !wi.length || wi.length >= ALL_INDUSTRIES.length;
        const allC = !wc.length || wc.length >= CATEGORIES.length;
        setWatchAllInd(allI); setInds(allI ? [] : wi);
        setAllRisks(allC); setCats(allC ? [] : wc);
      } catch { /* defaults */ }
      finally { if (!cancelled) setLoading(false); }
    })();
    return () => { cancelled = true; };
  }, [user, authLoading]);

  function toggle(list, set, v) { set(list.includes(v) ? list.filter(x => x !== v) : [...list, v]); }

  function applyPersona(p) {
    setActivePersona(p.key);
    // categories
    if (p.cats.length >= CATEGORIES.length) { setAllRisks(true); setCats([]); }
    else { setAllRisks(false); setCats(p.cats); }
    // industries
    if (p.all || !p.families) { setWatchAllInd(true); setInds([]); }
    else {
      const list = SECTORS.filter(([s]) => p.families.includes(s)).flatMap(([, l]) => l);
      setWatchAllInd(false); setInds(list);
    }
  }

  function clearEdition() {
    setActivePersona(null);
    setWatchAllInd(true); setInds([]);
    setAllRisks(true); setCats([]);
    setFreq("daily");
  }

  async function confirm() {
    setSaving(true); setError(null); setSaved(false);
    try {
      const { error: e } = await supabase.rpc("update_subscription_prefs", {
        p_watch_industries: watchAllInd ? ALL_INDUSTRIES : inds,
        p_watch_categories: allRisks ? ALL_CATS : cats,
        p_digest_frequency: freq,
        p_email_subscribed: subscribed,
      });
      if (e) throw e;
      await refreshProfile?.();
      setSaved(true);
      setTimeout(() => setSaved(false), 4000);
    } catch (err) { setError(err?.message || "Could not save. Try again."); }
    finally { setSaving(false); }
  }

  const riskCount = allRisks ? 13 : cats.length;
  const indCount = watchAllInd ? ALL_INDUSTRIES.length : inds.length;
  const empty = !activePersona && watchAllInd && allRisks;

  // ── shared styles ──
  const sec = { padding: "30px 0", borderTop: `1px solid ${C.line}` };
  const modNum = { fontFamily: MONO, fontSize: 12, fontWeight: 600, color: C.goldDeep };
  const modTitle = { fontWeight: 700, fontSize: 21, letterSpacing: "-0.01em", color: C.ink };
  const modSub = { color: C.ink3, fontSize: 14, maxWidth: "62ch", margin: "8px 0 20px", lineHeight: 1.55 };
  const linkBtn = { background: "none", border: "none", color: C.ink, fontWeight: 600, fontSize: 13, cursor: "pointer", padding: "2px 0", borderBottom: `2px solid ${C.gold}` };

  function Chip({ active, onClick, children, small }) {
    return (
      <button type="button" onClick={onClick} style={{
        padding: small ? "6px 11px" : "8px 13px",
        background: active ? C.ink : C.paper,
        color: active ? C.paper : C.ink2,
        border: `1px solid ${active ? C.ink : C.line2}`,
        borderRadius: 6, cursor: "pointer", fontFamily: FONT,
        fontSize: small ? 12 : 13, fontWeight: 500, transition: "all 140ms ease",
        position: "relative",
      }}>
        {active && <span style={{ color: C.gold, marginRight: 6, fontWeight: 800 }}>✓</span>}
        {children}
      </button>
    );
  }

  return (
    <div style={{ minHeight: "100vh", background: C.paper, color: C.ink, fontFamily: FONT, WebkitFontSmoothing: "antialiased" }}>
      <FontLoader />
      <div style={{ background: "#080808" }}><SiteNav active="subscriptions" /></div>
      <div style={{ height: 3, background: C.gold }} />

      {/* HERO */}
      <section style={{ borderBottom: `1px solid ${C.line}`, padding: "56px 0 40px", background: C.paper }}>
        <div style={{ maxWidth: 1180, margin: "0 auto", padding: "0 28px" }}>
          <div style={{ fontFamily: MONO, fontSize: 11, fontWeight: 500, letterSpacing: "0.18em", textTransform: "uppercase", color: C.ink3 }}>Compose your intelligence · live daily</div>
          <h1 style={{ fontWeight: 800, fontSize: "clamp(34px, 4.6vw, 52px)", lineHeight: 1.04, letterSpacing: "-0.03em", maxWidth: "18ch", margin: "16px 0 0", color: C.ink }}>
            The risks that matter, <span style={{ background: `linear-gradient(180deg,transparent 62%, ${C.gold} 62%, ${C.gold} 92%, transparent 92%)`, padding: "0 2px" }}>before</span> they reach the headlines.
          </h1>
          <p style={{ fontSize: 17, color: C.ink2, maxWidth: "58ch", lineHeight: 1.5, marginTop: 18 }}>
            Pick a role to start, then tune the risk categories and sectors that are yours. We only send what you compose here.
          </p>
          <div style={{ display: "flex", flexWrap: "wrap", border: `1px solid ${C.line}`, borderRadius: 10, overflow: "hidden", width: "fit-content", maxWidth: "100%", marginTop: 30, background: C.paper2 }}>
            {[["13", "GUARD categories"], ["43", "Industries"], ["Daily", "Sweep cadence"]].map(([n, l]) => (
              <div key={l} style={{ padding: "16px 26px", borderRight: `1px solid ${C.line}` }}>
                <div style={{ fontFamily: MONO, fontSize: 24, fontWeight: 600, color: C.ink }}>{n === "13" || n === "43" ? <>{n}</> : n}</div>
                <div style={{ fontSize: 11.5, color: C.ink3, marginTop: 1 }}>{l}</div>
              </div>
            ))}
          </div>
        </div>
      </section>

      {/* COMPOSER */}
      <div style={{ maxWidth: 1180, margin: "0 auto", padding: "8px 28px 80px", display: "grid", gridTemplateColumns: "minmax(0,1fr) 348px", gap: 56, alignItems: "start" }}>
        {/* MAIN */}
        <div style={{ minWidth: 0 }}>
          {loading ? (
            <div style={{ padding: 80, textAlign: "center", color: C.ink4 }}>Loading your edition…</div>
          ) : (
            <>
              {/* 01 — ROLE */}
              <section style={{ ...sec, borderTop: "none", paddingTop: 36 }}>
                <span style={modNum}>01</span>
                <div style={modTitle}>Start with your role</div>
                <div style={modSub}>Pick the role that fits — we'll preset your risks and sectors. You can fine-tune everything below.</div>
                <div style={{ display: "grid", gridTemplateColumns: "repeat(2,1fr)", gap: 12 }}>
                  {PERSONAS.map(p => {
                    const on = activePersona === p.key;
                    return (
                      <button key={p.key} type="button" onClick={() => applyPersona(p)} style={{
                        textAlign: "left", background: C.paper, border: `1px solid ${on ? C.ink : C.line2}`,
                        borderRadius: 10, padding: 18, cursor: "pointer", position: "relative", overflow: "hidden",
                        boxShadow: on ? "0 8px 28px rgba(16,16,16,0.08)" : "none", transition: "all 160ms ease",
                      }}>
                        {on && <span style={{ position: "absolute", top: 0, left: 0, width: 4, height: "100%", background: C.gold }} />}
                        <div style={{ fontFamily: MONO, fontSize: 10, letterSpacing: "0.1em", textTransform: "uppercase", color: C.ink4 }}>Persona {p.k}</div>
                        <div style={{ fontWeight: 700, fontSize: 16.5, margin: "6px 0 4px", color: C.ink }}>{p.title}</div>
                        <div style={{ fontSize: 13, color: C.ink3, lineHeight: 1.45 }}>{p.desc}</div>
                      </button>
                    );
                  })}
                </div>
              </section>

              {/* 02 — RISK CATEGORIES */}
              <section style={sec}>
                <span style={modNum}>02</span>
                <div style={{ display: "flex", alignItems: "baseline", justifyContent: "space-between", gap: 14 }}>
                  <div style={modTitle}>Risk category alerts</div>
                  <button style={linkBtn} onClick={() => { setAllRisks(true); setCats([]); setActivePersona(null); }}>Track all 13</button>
                </div>
                <div style={modSub}>Know the moment a material incident lands in a category you care about. Each maps to the GUARD framework.</div>
                <div style={{ display: "flex", gap: 8, flexWrap: "wrap", marginBottom: allRisks ? 0 : 16 }}>
                  <Chip active={allRisks} onClick={() => { setAllRisks(true); setCats([]); }}>◎ All 13 categories</Chip>
                  <Chip active={!allRisks} onClick={() => { setAllRisks(false); }}>Choose specific</Chip>
                </div>
                {!allRisks && (
                  <div style={{ display: "flex", gap: 8, flexWrap: "wrap", borderTop: `1px solid ${C.line}`, paddingTop: 16 }}>
                    {CATEGORIES.map(([code, label]) => (
                      <Chip key={code} small active={cats.includes(code)} onClick={() => { toggle(cats, setCats, code); setActivePersona(null); }}>
                        <span style={{ fontFamily: MONO, fontSize: 10.5, color: cats.includes(code) ? C.gold : C.ink4, marginRight: 6 }}>{code}</span>{label}
                      </Chip>
                    ))}
                  </div>
                )}
              </section>

              {/* 03 — SECTORS */}
              <section style={sec}>
                <span style={modNum}>03</span>
                <div style={{ display: "flex", alignItems: "baseline", justifyContent: "space-between", gap: 14 }}>
                  <div style={modTitle}>Sector intelligence</div>
                  <button style={linkBtn} onClick={() => { setWatchAllInd(true); setInds([]); setActivePersona(null); }}>Watch every sector</button>
                </div>
                <div style={modSub}>Tune everything to the industries you operate in — 43 industries across 13 sector families. Open a family to pick, or select all.</div>
                <div style={{ display: "flex", gap: 8, flexWrap: "wrap", marginBottom: watchAllInd ? 0 : 16 }}>
                  <Chip active={watchAllInd} onClick={() => { setWatchAllInd(true); setInds([]); }}>◎ All industries</Chip>
                  <Chip active={!watchAllInd} onClick={() => { setWatchAllInd(false); }}>Choose specific</Chip>
                </div>
                {!watchAllInd && (
                  <div style={{ borderTop: `1px solid ${C.line}`, marginTop: 4 }}>
                    {SECTORS.map(([sector, list]) => {
                      const sel = list.filter(i => inds.includes(i)).length;
                      const open = openSector === sector;
                      const allOn = sel === list.length;
                      return (
                        <div key={sector} style={{ borderBottom: `1px solid ${C.line}` }}>
                          <div style={{ display: "flex", alignItems: "center", justifyContent: "space-between", padding: "14px 2px", cursor: "pointer" }} onClick={() => setOpenSector(open ? null : sector)}>
                            <div style={{ fontWeight: 600, fontSize: 15, color: C.ink }}>{sector}
                              <span style={{ fontFamily: MONO, fontSize: 11, color: sel ? C.goldDeep : C.ink4, marginLeft: 10 }}>{sel ? `${sel}/${list.length}` : `${list.length} industries`}</span>
                            </div>
                            <div style={{ display: "flex", alignItems: "center", gap: 14 }}>
                              <button onClick={(e) => { e.stopPropagation(); setActivePersona(null); setInds(allOn ? inds.filter(i => !list.includes(i)) : [...new Set([...inds, ...list])]); }} style={linkBtn}>{allOn ? "Clear" : "Select all"}</button>
                              <span style={{ color: C.ink4, transform: open ? "rotate(180deg)" : "none", transition: "transform 150ms" }}>▾</span>
                            </div>
                          </div>
                          {open && (
                            <div style={{ display: "flex", gap: 7, flexWrap: "wrap", padding: "4px 2px 16px" }}>
                              {list.map(i => <Chip key={i} small active={inds.includes(i)} onClick={() => { toggle(inds, setInds, i); setActivePersona(null); }}>{i}</Chip>)}
                            </div>
                          )}
                        </div>
                      );
                    })}
                  </div>
                )}
              </section>

              {/* 04 — CADENCE */}
              <section style={sec}>
                <span style={modNum}>04</span>
                <div style={modTitle}>Cadence</div>
                <div style={modSub}>How often we write to you.</div>
                <div style={{ display: "flex", gap: 8 }}>
                  <Chip active={freq === "daily"} onClick={() => setFreq("daily")}>Daily brief</Chip>
                  <Chip active={freq === "weekly"} onClick={() => setFreq("weekly")}>Weekly rollup</Chip>
                </div>
              </section>

              {/* COMING SOON */}
              <section style={sec}>
                <span style={modNum}>05</span>
                <div style={modTitle}>More, soon</div>
                <div style={modSub}>We're building these into your edition next.</div>
                <div style={{ display: "grid", gridTemplateColumns: "repeat(auto-fill,minmax(240px,1fr))", gap: 12 }}>
                  {COMING.map(c => (
                    <div key={c.t} style={{ border: `1px solid ${C.line}`, borderRadius: 8, padding: "16px 16px", background: C.paper2, opacity: 0.92 }}>
                      <div style={{ display: "flex", alignItems: "center", gap: 8, marginBottom: 6 }}>
                        <span style={{ fontWeight: 700, fontSize: 14, color: C.ink }}>{c.t}</span>
                        <span style={{ fontFamily: MONO, fontSize: 9, color: C.goldDeep, border: `1px solid ${C.goldLine}`, borderRadius: 999, padding: "2px 7px", letterSpacing: "0.06em", textTransform: "uppercase" }}>Soon</span>
                      </div>
                      <div style={{ fontSize: 12.5, color: C.ink3, lineHeight: 1.5 }}>{c.d}</div>
                    </div>
                  ))}
                </div>
              </section>

              {/* MASTER */}
              <section style={sec}>
                <div style={{ display: "flex", alignItems: "center", justifyContent: "space-between", gap: 16, padding: "16px 18px", border: `1px solid ${C.line}`, borderRadius: 10, background: C.paper2 }}>
                  <div>
                    <div style={{ fontWeight: 700, fontSize: 15, color: C.ink }}>Email me my edition</div>
                    <div style={{ fontSize: 13, color: C.ink3, marginTop: 2 }}>{subscribed ? "Active — incidents land in your inbox." : "Paused — you'll receive nothing."}</div>
                  </div>
                  <button onClick={() => setSubscribed(s => !s)} aria-label="Toggle" style={{ flexShrink: 0, width: 46, height: 26, borderRadius: 13, background: subscribed ? C.gold : C.line2, border: "none", cursor: "pointer", position: "relative", transition: "background 180ms" }}>
                    <span style={{ position: "absolute", top: 3, left: subscribed ? 23 : 3, width: 20, height: 20, borderRadius: 10, background: "#fff", transition: "left 180ms", boxShadow: "0 1px 3px rgba(0,0,0,0.25)" }} />
                  </button>
                </div>
              </section>
            </>
          )}
        </div>

        {/* STICKY RAIL — YOUR EDITION */}
        {!loading && (
          <aside style={{ position: "sticky", top: 24 }}>
            <div style={{ border: `1px solid ${C.ink}`, borderRadius: 12, overflow: "hidden", boxShadow: "0 8px 28px rgba(16,16,16,0.08)" }}>
              <div style={{ background: C.ink, color: C.paper, padding: "18px 20px" }}>
                <div style={{ fontFamily: MONO, fontSize: 10, letterSpacing: "0.16em", textTransform: "uppercase", color: C.gold }}>Your edition</div>
                <div style={{ fontWeight: 700, fontSize: 17, marginTop: 6 }}>
                  {empty ? "Everything — the full sweep" : `${riskCount} ${riskCount === 1 ? "risk" : "risks"} · ${indCount} ${indCount === 1 ? "industry" : "industries"}`}
                </div>
              </div>
              <div style={{ padding: "18px 20px", background: C.paper }}>
                <div style={{ fontFamily: MONO, fontSize: 10, letterSpacing: "0.12em", textTransform: "uppercase", color: C.ink4, marginBottom: 8 }}>Deliver to</div>
                <input value={email} onChange={e => setEmail(e.target.value)} readOnly
                  style={{ width: "100%", padding: "11px 13px", border: `1px solid ${C.line2}`, borderRadius: 6, fontFamily: FONT, fontSize: 13.5, color: C.ink, background: C.paper2, boxSizing: "border-box" }} />

                <div style={{ display: "flex", flexWrap: "wrap", gap: 8, margin: "16px 0" }}>
                  {[`${riskCount} risk${riskCount === 1 ? "" : "s"}`, `${indCount} ${indCount === 1 ? "industry" : "industries"}`, freq === "weekly" ? "Weekly" : "Daily", subscribed ? "Email on" : "Email off"].map(t => (
                    <span key={t} style={{ fontFamily: MONO, fontSize: 10.5, color: C.ink2, background: C.paper3, border: `1px solid ${C.line}`, borderRadius: 999, padding: "5px 10px" }}>{t}</span>
                  ))}
                </div>

                <button onClick={confirm} disabled={saving} style={{
                  width: "100%", padding: "13px 16px", background: C.gold, color: "#1A1A1A",
                  border: "none", borderRadius: 6, cursor: saving ? "wait" : "pointer",
                  fontFamily: FONT, fontWeight: 700, fontSize: 13, letterSpacing: "0.04em", textTransform: "uppercase",
                  opacity: saving ? 0.7 : 1,
                }}>{saving ? "Saving…" : "Confirm subscriptions"}</button>

                {saved && <div style={{ marginTop: 12, fontSize: 12.5, color: C.ok, fontWeight: 600, textAlign: "center" }}>✓ Your edition is live.</div>}
                {error && <div style={{ marginTop: 12, fontSize: 12, color: C.err, textAlign: "center" }}>{error}</div>}

                <button onClick={clearEdition} style={{ width: "100%", marginTop: 10, background: "none", border: "none", color: C.ink3, fontFamily: FONT, fontSize: 12, cursor: "pointer", textDecoration: "underline" }}>Clear edition</button>
                <div style={{ marginTop: 12, fontSize: 10.5, color: C.ink4, textAlign: "center", lineHeight: 1.5 }}>No spam. Every email carries a one-click unsubscribe.</div>
              </div>
            </div>
          </aside>
        )}
      </div>

      <SiteFooter />
    </div>
  );
}
